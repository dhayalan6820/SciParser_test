# Frontend environment configuration
#
# All values are read by Frontend/src/config.ts, the single source of truth
# for environment-specific frontend values. Copy this file to `.env` (or
# `.env.local`) and adjust as needed. Vite only exposes variables prefixed
# with `VITE_` to client-side code.

# ---------------------------------------------------------------------------
# API / WebSocket base URLs
# ---------------------------------------------------------------------------
# Base URL the frontend uses for backend HTTP API calls.
# - Leave BLANK for same-origin requests (default, correct for local dev via
#   the Vite proxy below, and for production deployments where the frontend
#   is served from the same origin as the backend).
# - Set to an absolute URL (e.g. https://api.example.com) only if the API is
#   hosted on a different origin than the frontend in production.
VITE_API_BASE_URL=

# Base URL used for WebSocket connections (chat/plan/browser streams).
# - Leave BLANK to auto-derive from VITE_API_BASE_URL (or, if that's also
#   blank, from the current page's origin — ws:// for http, wss:// for
#   https). This matches current same-origin behavior.
# - Set explicitly (e.g. wss://api.example.com) only if WebSockets are
#   served from a different origin than the page in production.
VITE_WS_BASE_URL=

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------
# Backend target the Vite dev server proxies `/sciparser` requests to.
# Safe to leave as the default for local development.
VITE_DEV_PROXY_TARGET=http://localhost:8000

# ---------------------------------------------------------------------------
# Connect Your Browser (CDP)
# ---------------------------------------------------------------------------
# Default value pre-filled into the "Connect Your Browser" CDP URL input.
# Safe to leave as the default; users can always type their own URL.
VITE_DEFAULT_CDP_URL=http://localhost:9222
