# ===========================================================================
# SciParser — Unified Environment Configuration
# ===========================================================================
# This is the SINGLE source of truth for ALL environment variables used by
# both the Backend and Frontend. Edit this file once — changes propagate
# to both systems automatically.
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# .env is gitignored and never committed.
# ===========================================================================


# ===========================================================================
# ENVIRONMENT
# ===========================================================================
# "development" (default) or "production".
# Controls whether secrets are required or fall back to dev defaults.
ENVIRONMENT=development


# ===========================================================================
# SECURITY / AUTH — REQUIRED IN PRODUCTION
# ===========================================================================
# Secret key for signing JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If blank in development, a random key is generated per process (sessions
# won't survive a restart). REQUIRED in production — startup fails if unset.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=900


# ===========================================================================
# DATABASE — REQUIRED IN PRODUCTION
# ===========================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sciparser_v1


# ===========================================================================
# LLM / API KEYS — REQUIRED IN PRODUCTION
# ===========================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Model assignments — each controls a different subsystem:
#   MAIN_MODEL           → Brain's primary reasoning LLM (brain.py)
#   TOOL_SELECTION_MODEL → Embedding/similarity for tool selection (tool_selector.py)
#   CODE_GENERATION_MODEL→ Script generation LLM (brain.py CodeProcessor)
#   BROWSER_USE_MODEL    → Browser-use MCP bridge LLM (mcp_agent.py → bridge subprocess)
#   LLM_EXTRACTION_MODEL → Data extraction from pages (browser_use_bridge.py)
MAIN_MODEL=google/gemini-3-flash-preview
TOOL_SELECTION_MODEL=minimax/minimax-m3
CODE_GENERATION_MODEL=openai/gpt-5.1-codex-mini
BROWSER_USE_MODEL=openai/gpt-4o-mini-2024-07-18
LLM_EXTRACTION_MODEL=openai/gpt-4o-mini-2024-07-18

# Optional — enables web search tools
TAVILY_API_KEY=

# Optional — Google API key
GOOGLE_API_KEY=


# ===========================================================================
# LLM COST PRICING (per million tokens)
# ===========================================================================
LLM_INPUT_COST_PER_MILLION=0.1
LLM_OUTPUT_COST_PER_MILLION=0.4


# ===========================================================================
# SERVER
# ===========================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# ===========================================================================
# CORS
# ===========================================================================
# Comma-separated allowed origins. "*" for dev, restrict in production.
CORS_ALLOWED_ORIGINS=*
# CORS_ALLOW_WILDCARD_IN_PRODUCTION=false


# ===========================================================================
# SMTP / EMAIL (optional — leave blank to disable)
# ===========================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TIMEOUT_SECONDS=15


# ===========================================================================
# HTTP CLIENT TIMEOUTS (seconds)
# ===========================================================================
HTTP_CLIENT_TIMEOUT_SECONDS=6
CDP_JSON_TIMEOUT_SECONDS=3
CDP_SCREENSHOT_TIMEOUT_SECONDS=8
PROXY_TEST_TIMEOUT_SECONDS=10


# ===========================================================================
# BROWSER AUTOMATION
# ===========================================================================
BROWSER_ENGINE=chrome
BROWSER_DEFAULT_CDP_HOST=localhost
BROWSER_DEFAULT_CDP_PORT=9222
BROWSER_CDP_READY_TIMEOUT_SECONDS=90
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_USE_HEADLESS=false
BROWSER_PROXY_URL=

# System Chrome settings (set BROWSER_USE_SYSTEM_CHROME=true to reuse your
# installed Chrome with its existing profile, cookies, and extensions)
BROWSER_USE_SYSTEM_CHROME=false
BROWSER_EXECUTABLE_PATH=
BROWSER_USER_DATA_DIR=
BROWSER_PROFILE_DIRECTORY=Default


# ===========================================================================
# LANGSMITH TRACING (optional)
# ===========================================================================
# Traces every LLM call, LangGraph step, and tool invocation automatically.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=SciParser-AI
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ===========================================================================
# TELEMETRY OPT-OUT
# ===========================================================================
CREWAI_TRACING_ENABLED=false
CREWAI_TELEMETRY_OPT_OUT=true


# ===========================================================================
# THIRD-PARTY CHECK ENDPOINTS
# ===========================================================================
IP_CHECK_URL=https://api.ipify.org?format=json
DEFAULT_TARGET_DOMAIN=google.com


# ===========================================================================
# FRONTEND (VITE) — Variables below are exposed to browser code
# ===========================================================================
# API / WebSocket base URLs for the frontend.
# Leave BLANK for same-origin requests (Vite proxy in dev, reverse proxy in prod).
# Set to absolute URLs only if API is on a different domain.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Backend target the Vite dev server proxies /sciparser requests to.
# Must match SERVER_HOST:SERVER_PORT above.
VITE_DEV_PROXY_TARGET=http://localhost:8000

# Default CDP URL pre-filled in the "Connect Your Browser" input.
VITE_DEFAULT_CDP_URL=http://localhost:9222
