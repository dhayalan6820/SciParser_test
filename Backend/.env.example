# SciParser Backend — environment configuration
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
# Then fill in real values. `.env` is gitignored and never committed.
#
# In production (ENVIRONMENT=production), all variables marked "REQUIRED IN
# PRODUCTION" below MUST be set via Replit Secrets — the app will fail fast
# at startup if they are missing. In development they fall back to safe,
# clearly-labeled insecure defaults so the app still runs without a .env file.
#
# See Backend/src/config.py — the single source of truth that reads these
# variables. No other module should hardcode a URL, secret, or read these
# vars directly; everything should import from src.config.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# "development" (default) or "production". Controls whether secrets are
# required or allowed to fall back to dev defaults.
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Security / Auth — REQUIRED IN PRODUCTION
# ---------------------------------------------------------------------------
# Secret key used to sign JWT access tokens. Must be a long, random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# If left blank in development, the app generates a random secret in memory
# for that process only (sessions won't survive a restart). REQUIRED in
# production — startup fails if unset.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=900

# ---------------------------------------------------------------------------
# Database — REQUIRED IN PRODUCTION
# ---------------------------------------------------------------------------
# Postgres connection string (Replit's built-in database provides this
# automatically as DATABASE_URL when a database is provisioned).
DATABASE_URL=postgresql://user:password@localhost:5432/sciparser

# ---------------------------------------------------------------------------
# LLM / third-party API keys — REQUIRED IN PRODUCTION
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Optional — enables web search tools. Features that need it will raise a
# clear error at call time if unset; the app still starts without it.
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Defaults to "*" in development.
# In production, set this to your real frontend origin(s), e.g.:
#   CORS_ALLOWED_ORIGINS=https://your-app.replit.app
# If ENVIRONMENT=production and this is left as "*" (or unset), startup fails
# fast with an error, since a wildcard lets any site make authenticated
# cross-origin requests against the API. To explicitly allow a wildcard in
# production anyway (not recommended), set CORS_ALLOW_WILDCARD_IN_PRODUCTION=true.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_WILDCARD_IN_PRODUCTION=false

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---------------------------------------------------------------------------
# SMTP / email notifications (optional — leave blank to disable email)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TIMEOUT_SECONDS=15

# ---------------------------------------------------------------------------
# HTTP client timeouts (seconds)
# ---------------------------------------------------------------------------
HTTP_CLIENT_TIMEOUT_SECONDS=6
CDP_JSON_TIMEOUT_SECONDS=3
CDP_SCREENSHOT_TIMEOUT_SECONDS=8
PROXY_TEST_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Browser automation
# ---------------------------------------------------------------------------
# "camoufox" (default) or "browser-use"
BROWSER_ENGINE=camoufox
BROWSER_DEFAULT_CDP_HOST=localhost
BROWSER_DEFAULT_CDP_PORT=9222
BROWSER_CDP_READY_TIMEOUT_SECONDS=90
BROWSER_NAVIGATION_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# LangSmith Tracing (optional — leave blank to disable)
# ---------------------------------------------------------------------------
# When LANGCHAIN_TRACING_V2=true and LANGCHAIN_API_KEY is set, LangChain
# automatically traces every LLM call, LangGraph execution, and tool
# invocation to the LangSmith dashboard (https://smith.langchain.com).
# No code changes needed — it hooks into ChatOpenAI, StateGraph.ainvoke,
# and tool calls transparently.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=SciParser-AI
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---------------------------------------------------------------------------
# Third-party check endpoints / defaults
# ---------------------------------------------------------------------------
IP_CHECK_URL=https://api.ipify.org?format=json
DEFAULT_TARGET_DOMAIN=google.com
